# Salin file ini menjadi .env lalu isi sesuai kebutuhan
# jalankan: cp .env.example .env

# --- Flask ---
SECRET_KEY=ganti-dengan-string-acak-panjang
PORT=5000
FLASK_DEBUG=false

# --- TCP upload server ---
TCP_HOST=127.0.0.1
TCP_PORT=5001

# --- UDP streaming server ---
UDP_DATA_PORT=5002
UDP_CONTROL_HOST=127.0.0.1
UDP_CONTROL_PORT=5003

# --- SMTP untuk kirim kode verifikasi login ---
# Contoh pakai Gmail: aktifkan 2FA lalu buat "App Password" di
# https://myaccount.google.com/apppasswords, jangan pakai password akun biasa.
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=akunkamu@gmail.com
MAIL_PASSWORD=app-password-16-digit

# Catatan: jika MAIL_USERNAME/MAIL_PASSWORD dikosongkan, kode OTP akan
# tercetak di console server (mode demo) — berguna untuk testing cepat
# tanpa perlu setup SMTP.
