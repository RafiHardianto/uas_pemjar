[Unit]
Description=UAS Pemrograman Jaringan - Web App (Flask)
After=network.target pj-tcp.service pj-udp.service
Wants=pj-tcp.service pj-udp.service

[Service]
Type=simple
User=%i
WorkingDirectory=/opt/uas-pemjar
EnvironmentFile=/opt/uas-pemjar/.env
ExecStart=/opt/uas-pemjar/venv/bin/python3 /opt/uas-pemjar/app.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
